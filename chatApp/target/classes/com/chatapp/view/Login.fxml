<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="350.0" prefWidth="400.0" spacing="15.0" 
      style="-fx-background-color: linear-gradient(to bottom right, #0F2027, #203A43, #2C5364);" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.chatapp.controller.LoginController">
   <children>
      <VBox alignment="CENTER" spacing="12.0" maxWidth="300.0"
            style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 12px; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-radius: 12px; -fx-border-width: 1px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 10);">
         <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
         </padding>
         <children>
            <!-- 1. Username Input Field -->
            <TextField fx:id="usernameField" minWidth="240.0" maxWidth="240.0" promptText="Username" 
                       style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-text-fill: white; -fx-prompt-text-fill: #718096; -fx-background-radius: 6px; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-radius: 6px; -fx-padding: 8px;">
               <font>
                  <Font name="Segoe UI" size="13.0" />
               </font>
            </TextField>
            
            <!-- 2. Password Input Field -->
            <PasswordField fx:id="passwordField" minWidth="240.0" maxWidth="240.0" promptText="Password" 
                           style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-text-fill: white; -fx-prompt-text-fill: #718096; -fx-background-radius: 6px; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-radius: 6px; -fx-padding: 8px;">
               <font>
                  <Font name="Segoe UI" size="13.0" />
               </font>
            </PasswordField>
            
            <!-- 3. Login Button -->
            <Button fx:id="loginButton" minWidth="240.0" maxWidth="240.0" mnemonicParsing="false" onAction="#handleLogin" text="Login" 
                    style="-fx-background-color: linear-gradient(to right, #00f2fe, #4facfe); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 10px; -fx-cursor: hand;">
               <font>
                  <Font name="Segoe UI Bold" size="13.0" />
               </font>
            </Button>
            
            <!-- 4. Sign In Button -->
            <Button fx:id="signInButton" minWidth="240.0" maxWidth="240.0" mnemonicParsing="false" onAction="#handleSignIn" text="Sign In" 
                    style="-fx-background-color: transparent; -fx-text-fill: #00ffcc; -fx-font-weight: bold; -fx-border-color: #00ffcc; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-padding: 8px; -fx-cursor: hand;">
               <font>
                  <Font name="Segoe UI Bold" size="13.0" />
               </font>
            </Button>

            <!-- 5. Feedback Label for authentication status messages -->
            <Label fx:id="feedbackLabel" alignment="CENTER" minWidth="240.0" maxWidth="240.0" textAlignment="CENTER" wrapText="true">
               <font>
                  <Font name="Segoe UI" size="12.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </children>
</VBox>
